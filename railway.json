{
  "$schema": "https://railway.app/json-schema.json",
  "build": {
    "builder": "V2"
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "web": {
      "image": "node:20",
      "variables": {
        "NODE_ENV": "production",
        "GROK_API": "${GROK_API_KEY}"
      }
    },
    "postgres": {
      "image": "postgres:16"
    },
    "redis": {
      "image": "redis:7"
    }
  }
}